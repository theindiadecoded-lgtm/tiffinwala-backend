# ─────────────────────────────────────────────
#  .env.example
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to GitHub!
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=3000
NODE_ENV=development          # change to "production" when deploying

# ── Database (Supabase PostgreSQL) ──────────
# Get from: https://supabase.com → Project → Settings → Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# ── Redis (Upstash) ─────────────────────────
# Get from: https://console.upstash.com
REDIS_URL="redis://default:[YOUR-TOKEN]@[YOUR-ENDPOINT].upstash.io:6379"

# ── JWT ─────────────────────────────────────
# Use any long random string — keep it SECRET
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"            # token valid for 7 days

# ── Firebase Admin (for OTP via Firebase Auth) ──
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"

# ── Razorpay (Payments) ─────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# ── SMS OTP (fallback via Fast2SMS) ─────────
# Get from: https://www.fast2sms.com (cheap Indian SMS)
FAST2SMS_API_KEY="your-fast2sms-key"

# ── WATI / Twilio (WhatsApp) ────────────────
WATI_API_KEY="your-wati-api-key"
WATI_API_ENDPOINT="https://live-server-XXXXX.wati.io"

# ── Google Maps ─────────────────────────────
GOOGLE_MAPS_API_KEY="your-google-maps-key"
